# Environment
ENVIRONMENT=development
DEBUG=true

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Database
# SQLite path - create relative to project
DATABASE_URL=sqlite:///./data/premarket.db

# Market data
TOP_N_TICKERS=10
SCAN_INTERVAL_MINUTES=5
# Measure the gap against the latest real pre/post-market trade (vs. daily open)
USE_PREMARKET_DATA=true

# Swing trading rules (initial defaults)
GAP_THRESHOLD_PERCENT=2.0
VOLUME_MULTIPLIER=1.5
NEWS_LOOKBACK_HOURS=48

# Claude API
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here

# Alerts — notify on strong candidates (clears the tighter thresholds below).
# Only fires when at least one channel (Telegram or Discord) is configured.
ALERTS_ENABLED=true
ALERT_GAP_THRESHOLD_PERCENT=4.0
ALERT_RVOL_THRESHOLD=2.0
# Telegram: create a bot with @BotFather, then get your numeric chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord: a channel webhook URL (Server Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=
