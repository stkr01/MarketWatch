# Production .env for skzdev02 — copy to /opt/premarket/backend/.env and fill in.
# This file is a template (safe to commit); the real .env is gitignored.

ENVIRONMENT=production
DEBUG=false

# Backend binds to 127.0.0.1:8000 (via systemd ExecStart); nginx proxies to it.
API_HOST=127.0.0.1
API_PORT=8000

# SQLite lives outside the code tree so redeploys never touch it.
DATABASE_URL=sqlite:////opt/premarket/data/premarket.db

# Market data / screening
TOP_N_TICKERS=10
SCAN_INTERVAL_MINUTES=5
USE_PREMARKET_DATA=true

# Swing rules (also live-editable from the UI once running)
GAP_THRESHOLD_PERCENT=2.0
VOLUME_MULTIPLIER=1.5
NEWS_LOOKBACK_HOURS=48

# Claude API — required for analysis + briefing
ANTHROPIC_API_KEY=your-key-here

# Alerts
ALERTS_ENABLED=true
ALERT_GAP_THRESHOLD_PERCENT=4.0
ALERT_RVOL_THRESHOLD=2.0
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
DISCORD_WEBHOOK_URL=
